{
  "name": "HUVI_SDR_Agent",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "huvi-sdr-webhook",
        "options": {}
      },
      "id": "Webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// A Evolution API manda eventos, geralmente messages.upsert\nif (body.event !== 'messages.upsert') {\n  return []; // Ignorar outros eventos\n}\n\nconst msg = body.data?.message || {};\nconst fromMe = body.data?.key?.fromMe;\nconst remoteJid = body.data?.key?.remoteJid || '';\nconst pushName = body.data?.pushName || '';\nconst instanceName = body.instance || '';\n\n// Ignora mensagens enviadas pelo próprio bot ou de grupos\nif (fromMe || remoteJid.includes('@g.us')) {\n  return [];\n}\n\n// Extrai texto (pode vir em conversation ou extendedTextMessage)\nconst text = msg.conversation || msg.extendedTextMessage?.text || '';\nif (!text) {\n  return [];\n}\n\n// Extrair número limpo\nconst phone = remoteJid.split('@')[0];\n\nreturn [{\n  json: {\n    phone,\n    text,\n    pushName,\n    remoteJid,\n    instanceName\n  }\n}];"
      },
      "id": "FilterMessages",
      "name": "Filter Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "tenant_settings",
        "filters": {
          "conditions": [
            {
              "condition": "eq",
              "keyName": "setting_value",
              "keyValue": "={{ $json.instanceName }}"
            },
            {
              "condition": "eq",
              "keyName": "setting_key",
              "keyValue": "evolution_instance"
            }
          ]
        }
      },
      "id": "GetTenantByInstance",
      "name": "Get Tenant",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        420,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "8TEbcDMv4pFPkspM",
          "name": "HUVIbase"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "if ($input.all().length === 0) return [];\nconst tenant_id = $input.first().json.tenant_id;\nconst prev = $('Filter Messages').first().json;\n\nreturn [{\n  json: {\n    ...prev,\n    tenant_id\n  }\n}];"
      },
      "id": "MergeTenant",
      "name": "Merge Tenant",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        300
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "opportunities",
        "filters": {
          "conditions": [
            {
              "condition": "eq",
              "keyName": "tenant_id",
              "keyValue": "={{ $json.tenant_id }}"
            },
            {
              "condition": "ilike",
              "keyName": "phone",
              "keyValue": "=%{{ $json.phone.substring($json.phone.length - 8) }}%"
            }
          ]
        }
      },
      "id": "GetOpportunity",
      "name": "Get Opportunity",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        800,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "8TEbcDMv4pFPkspM",
          "name": "HUVIbase"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "if ($input.all().length === 0) return [];\nconst opp = $input.first().json;\nconst msgData = $('Merge Tenant').first().json;\n\nreturn [{\n  json: {\n    ...msgData,\n    opportunity_id: opp.id,\n    company_name: opp.company_name\n  }\n}];"
      },
      "id": "MergeOpportunity",
      "name": "Merge Opportunity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/huvi-brain",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "prompt",
              "value": "={{ $json.text }}"
            },
            {
              "name": "system_message",
              "value": "Você é o SDR do HUVI. Analise a seguinte mensagem do lead e classifique a intenção dele. Retorne APENAS UM JSON no seguinte formato: {\"intent\": \"request_media\"} se o lead estiver pedindo para ver imagem, vídeo, foto, catálogo ou produto. Caso contrário, retorne {\"intent\": \"chat\", \"response\": \"Sua resposta de conversação aqui\"}."
            }
          ]
        },
        "options": {}
      },
      "id": "HUVIBrain",
      "name": "HUVI Brain Intention",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2550,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const responseText = $input.first().json.text || '';\nlet parsed = { intent: 'chat', response: responseText };\ntry {\n  const cleanJson = responseText.replace(/```json/gi, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleanJson);\n} catch (e) {}\n\nconst msgData = $('Merge Opportunity').first().json;\n\nreturn [{\n  json: {\n    ...msgData,\n    intent: parsed.intent || 'chat',\n    ai_response: parsed.response || ''\n  }\n}];"
      },
      "id": "ParseBrain",
      "name": "Parse Brain",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2750,
        300
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "intent-media",
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "request_media",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "request_media"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "id": "intent-chat",
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "chat",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "chat"
            }
          ]
        },
        "options": {}
      },
      "id": "SwitchIntent",
      "name": "Switch Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        2950,
