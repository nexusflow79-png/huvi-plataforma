    {
      "parameters": {
        "jsCode": "if ($input.all().length === 0) {\n  // Se não tem oferta ativa, mandar pro chat fallback\n  return [];\n}\nconst offer = $input.first().json;\nconst msgData = $('Switch Intent').first().json;\n\nreturn [{\n  json: {\n    ...msgData,\n    offer_name: offer.name,\n    image_url: offer.image_url,\n    video_url: offer.video_url,\n    has_media: !!(offer.image_url || offer.video_url)\n  }\n}];"
      },
      "id": "CheckMediaData",
      "name": "Check Media Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3400,
        150
      ]
    },
    {
