      "id": "GoogleCalendarTrigger",
      "name": "Google Calendar Trigger",
      "type": "n8n-nodes-base.googleCalendarTrigger",
      "typeVersion": 1.1,
      "position": [
        200,
        240
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "h7R1a8f9k2jL5pQw",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const event = $input.first()?.json || {};\nconst attendees = event.attendees || [];\n\n// Extrai o e-mail de um convidado que não seja o dono da agenda (tenant)\n// Geralmente é o primeiro e-mail da lista que não é o organizador\nlet guestEmail = null;\nfor (const a of attendees) {\n  if (!a.organizer && a.email) {\n    guestEmail = a.email.trim();\n    break;\n  }\n}\n\n// Se não achar nas flags de organizador, pega o primeiro que não seja o organizador\nif (!guestEmail && attendees.length > 0) {\n  guestEmail = attendees.find(a => !a.self)?.email || attendees[0].email;\n}\n\nreturn [{\n  json: {\n    guest_email: guestEmail || '',\n    event_summary: event.summary || 'Reunião Agendada',\n    event_link: event.htmlLink || '',\n    start_time: event.start?.dateTime || new Date().toISOString()\n  }\n}];"
      },
      "id": "ExtractGuestEmail",
      "name": "ExtractGuestEmail",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        240
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "schema": "public",
        "table": "opportunities",
        "limit": 1,
        "filters": {
          "conditions": [
            {
              "keyName": "email",
              "condition": "eq",
              "keyValue": "={{ $json.guest_email }}"
            },
            {
              "keyName": "deleted_at",
              "condition": "is",
              "keyValue": "null"
            }
          ]
        }
      },
      "id": "FindOpportunity",
      "name": "Find Opportunity",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
