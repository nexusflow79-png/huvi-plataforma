    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst summary = items[0]?.json?.summary || { found: 0, created: 0, duplicates: 0 };\nconst tenantId = $('Webhook').first().json.body.tenantId;\n\nconst creditsRow = $('Supabase - Get Credits').first().json;\n\nlet oldUsed = 0;\nlet weight = 2;\ntry {\n  oldUsed = parseInt(creditsRow.opportunity_used) || 0;\n  weight = parseInt(creditsRow.weight_firecrawl_search) || 2;\n} catch (e) {}\n\nconst newUsed = oldUsed + weight;\n\nreturn [{ json: { summary, tenantId, newUsed, weight } }];"
      },
