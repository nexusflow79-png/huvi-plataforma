      "name": "Firecrawl Search API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [880, 0],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Validar resposta e extrair dados\nconst input = $input.first().json;\n\nif (input.error || !input.data) {\n  const errorMsg = input.error?.message || input.message || 'Erro ao chamar Firecrawl Search API';\n  return [{ json: { apiError: true, errorMessage: errorMsg } }];\n}\n\nconst results = input.data;\n\nif (!results || !Array.isArray(results) || results.length === 0) {\n  return [{ json: { apiError: false, noResults: true, results: [] } }];\n}\n\n// Mapear resultados para formato HUVI\nconst leads = results.map(item => ({\n  title: item.title || item.metadata?.title || '',\n  url: item.url || '',\n  description: item.description || item.metadata?.description || '',\n  phone: null, // Será populado via scrape adicional\n  email: null\n}));\n\nreturn [{ json: { apiError: false, noResults: false, leads } }];"
      },
      "name": "Extrair Resultados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 0]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.apiError }}",
              "value2": false
            }
          ]
        }
      },
      "name": "IF - API Success",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1320, 0]
    },
