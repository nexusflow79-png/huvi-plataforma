    {
      "parameters": {
        "operation": "getAll",
        "table": "opportunities",
        "limit": 1000,
        "matchType": "allColumns",
        "matchColumns": "tenant_id",
        "matchValue": "={{$('Webhook').first().json.body.tenantId}}"
      },
      "name": "Supabase - Get Existing Opps",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1760, -300],
      "alwaysOutputData": true,
      "continueOnFail": true,
      "credentials": {
        "supabaseApi": {
          "id": "8TEbcDMv4pFPkspM",
          "name": "HUVIbase"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const tenantId = $('Webhook').first().json.body.tenantId;\nconst keywords = $('Webhook').first().json.body.keywords || [];\nconst leads = $('Extrair Resultados').first().json.leads;\nconst existingOpps = $input.all().map(e => e.json).filter(e => e && !e.error);\n\nlet validLeads = [];\nlet duplicates = 0;\n\nleads.forEach(lead => {\n  if (!lead.title && !lead.url) return;\n\n  const isDup = existingOpps.some(e =>\n    (e.website && lead.url && e.website === lead.url) ||\n    (e.phone && lead.phone && e.phone === lead.phone) ||\n    (e.email && lead.email && e.email === lead.email)\n  );\n\n  if (isDup) {\n    duplicates++;\n  } else {\n    let score = 0;\n    if (lead.phone) score += 15;\n    if (lead.url) score += 20;\n    if (lead.email) score += 15;\n    if (lead.description && lead.description.length > 100) score += 10;\n    if (lead.title && lead.title.length > 3) score += 10;\n\n    validLeads.push({\n      tenant_id: tenantId,\n      company_name: lead.title,\n      website: lead.url || null,\n      email: lead.email || null,\n      phone: lead.phone || null,\n      description: lead.description || null,\n      origin: 'Web Discovery',\n      source_service: 'Firecrawl',\n      status: score >= 60 ? 'scored' : 'discovered',\n      score: score\n    });\n  }\n});\n\nif (validLeads.length === 0) {\n  return [{ json: { summary: { found: leads.length, created: 0, duplicates: duplicates }, tenantId } }];\n}\n\nreturn validLeads.map(l => ({ json: { ...l, summary: { found: leads.length, created: validLeads.length, duplicates } } }));"
      },
      "name": "Deduplicação e Scoring",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, -300]
    },
